# kit.conf — everything you'd normally want to change lives here.
#
# Adding content later: append a line to the relevant array.
# Removing content: delete or comment the line, then run ./update --prune from
# the drive root to delete the orphaned files.

# ── Where the drive is ───────────────────────────────────────────────────────

KIT_ROOT="/Volumes/ark"

# ── Kiwix ZIMs ───────────────────────────────────────────────────────────────
#
# Format: "subdirectory:filename-prefix"
# The scripts resolve the newest dated build matching each prefix, so you never
# pin a date. Browse https://download.kiwix.org/zim/ to find more.

ZIMS=(
  "wikipedia:wikipedia_en_all_maxi"          # full EN Wikipedia, images  ~115 GB
  "wikipedia:wikipedia_en_medicine_maxi"     # medical subset, standalone   ~2 GB
  "other:wikem_en_all_maxi"                  # emergency medicine wiki
  "other:zimgit-medicine_en"                 # Where There Is No Doctor et al
  "other:zimgit-post-disaster_en"            # post-disaster guidance
  "other:zimgit-water_en"                    # water treatment
  "ifixit:ifixit_en_all"                     # repair guides, photos       ~5 GB
  "wiktionary:wiktionary_en_all_nopic"       # dictionary
  "gutenberg:gutenberg_en_all"               # books
)

# ── LLM models ───────────────────────────────────────────────────────────────
#
# Format: "local-filename|url"
# Leave the array empty to skip. See README for the hardware caveats.

MODELS=(
  "Qwen3.5-2B-Q8_0.llamafile|https://huggingface.co/mozilla-ai/llamafile_0.10/resolve/main/Qwen3.5-2B-Q8_0.llamafile"
  "gpt-oss-20b-mxfp4.llamafile|https://huggingface.co/mozilla-ai/llamafile_0.10/resolve/main/gpt-oss-20b-mxfp4.llamafile"
)

# The llamafile release to bundle in apps/ (leave empty to skip)
LLAMAFILE_RELEASE=""   # e.g. "https://github.com/Mozilla-Ocho/llamafile/releases/download/0.9.3/llamafile-0.9.3"

# ── App pantry ───────────────────────────────────────────────────────────────
#
# Ark can carry the app installers and portable binaries needed to use the kit.
# These are personal-kit payloads fetched by ./update into /apps/, not files
# checked into git.
#
# APPS format:
#   "platform|name|filename|url|sha256|notes"
#
# Leave sha256 empty if the upstream does not publish stable checksums. The
# download will still be size-verified, but the script will warn that it is not
# content-pinned.

APPS=(
  # "windows|example|example.exe|https://example.com/example.exe||Pinned portable app or installer"
)

# APP_RESOLVERS format:
#   "platform|name|resolver|asset-pattern|sha256|notes"
#
# Supported resolvers:
#   direct:<url>                 Uses asset-pattern as the destination filename.
#   github-release:<owner/repo>  Picks the first latest-release asset whose
#                                filename matches asset-pattern as an ERE.
#   mirror-latest:<dir-url>      Picks the newest file in a simple release
#                                directory whose filename matches asset-pattern.

APP_RESOLVERS=(
  "windows|kiwix-desktop|mirror-latest:https://download.kiwix.org/release/kiwix-desktop|^kiwix-desktop_windows_x64_[0-9].*\\.zip$||Portable Kiwix Desktop for Windows"
  "linux|kiwix-desktop|mirror-latest:https://download.kiwix.org/release/kiwix-desktop|^kiwix-desktop_x86_64_[0-9].*\\.appimage$||Kiwix Desktop AppImage for Linux x86_64"
  "macos|kiwix-tools-arm64|mirror-latest:https://download.kiwix.org/release/kiwix-tools|^kiwix-tools_macos-arm64-[0-9].*\\.tar\\.gz$||Kiwix command-line tools for Apple Silicon, including kiwix-serve"
  "macos|kiwix-tools-x86_64|mirror-latest:https://download.kiwix.org/release/kiwix-tools|^kiwix-tools_macos-x86_64-[0-9].*\\.tar\\.gz$||Kiwix command-line tools for Intel Macs, including kiwix-serve"
  "windows|kiwix-tools|mirror-latest:https://download.kiwix.org/release/kiwix-tools|^kiwix-tools_win-x86_64-[0-9].*\\.zip$||Kiwix command-line tools for Windows, including kiwix-serve"
  "linux|kiwix-tools|mirror-latest:https://download.kiwix.org/release/kiwix-tools|^kiwix-tools_linux-x86_64-musl-[0-9].*\\.tar\\.gz$||Kiwix command-line tools for Linux x86_64, including kiwix-serve"
  "android|kiwix|github-release:kiwix/kiwix-android|^v.*-universal-standalone\\.apk$||Universal Kiwix APK for Android local install"
)

# iOS/iPadOS cannot normally install app binaries from the drive. Keep App
# Store prep links here so /apps/ios/app-store-links.html can be generated.
#
# Format:
#   "name|url|notes"

IOS_APP_LINKS=(
  "Kiwix|https://apps.apple.com/app/kiwix/id997079563|Install before going offline for ZIM libraries"
  "VLC|https://apps.apple.com/app/vlc-media-player/id650377962|Install before going offline for broad media playback"
)

# ── Python tool wheelhouses ──────────────────────────────────────────────────
#
# Some Ark tools are Python applications rather than single portable binaries.
# ./update can carry their installable wheels under /apps/python/wheelhouse/
# so a prepared drive has the packages available without internet.
#
# Format:
#   "name|pip-package-spec|notes"

PYTHON_TOOL_PACKAGES=(
  "kolibri|kolibri|Offline wheelhouse for the Kolibri CLI and server"
  "argostranslate|argostranslate|Offline wheelhouse for Argos Translate tooling"
)

# ── Offline maps ─────────────────────────────────────────────────────────────
#
# Ark can carry app-ready offline map files and hosted web-map payloads. These
# are personal-kit downloads fetched by ./update into /maps/, not files checked
# into git.
#
# MAPS format:
#   "platform|provider|region|filename|url|sha256|notes"
#
# Suggested platform values:
#   android  App-specific mobile map files such as OsmAnd .obf.zip
#   ios      App-specific mobile map files where import is supported
#   web      Hosted browser map payloads such as .pmtiles
#   raw      Advanced source data such as Geofabrik .osm.pbf or .shp.zip

MAPS=(
  # "android|osmand|california|California_northamerica_2.obf.zip|https://download.osmand.net/download.php?standard=yes&file=California_northamerica_2.obf.zip||OsmAnd offline map for California"
  # "web|protomaps|sample-city|sample-city.pmtiles|https://example.com/sample-city.pmtiles||PMTiles for a future hosted web map"
  # "raw|geofabrik|portugal|portugal-latest.osm.pbf|https://download.geofabrik.de/europe/portugal-latest.osm.pbf||Raw OpenStreetMap extract for advanced conversion"
)

# MAP_RESOLVERS format:
#   "platform|provider|region|resolver|asset-pattern|sha256|notes"
#
# Supported resolvers:
#   direct:<url>                 Uses asset-pattern as the destination filename.
#   github-release:<owner/repo>  Picks the first latest-release asset whose
#                                filename matches asset-pattern as an ERE.

MAP_RESOLVERS=(
  # "web|protomaps|sample-city|direct:https://example.com/sample-city.pmtiles|sample-city.pmtiles||Direct PMTiles resolver example"
)

# ── Kolibri channels ─────────────────────────────────────────────────────────
#
# Format: "label|channel-id"
# Find IDs with:  kolibri manage listchannels
# or on Kolibri Studio / the Kolibri content browser.
# Command-line imports need the 32-character channel ID, not the shorter token.

KOLIBRI_CHANNELS=(
  # Small smoke test: one English math channel, under 1 GB.
  "pbs-family-math|b8bd7770063d40a8bd9b30d4703927b5"

  # Larger options for later:
  # "khan-academy-en-us|c9d7f950ab6b5a1199e3d6c10d7f0103"
  # "khan-academy-en-cbse-india|2fd54ca47a8f59c99fcefaaa3894c19e"
)

# ── Argos translate language pairs ───────────────────────────────────────────

ARGOS_PAIRS=(
  "en:pt"
  "pt:en"
  "en:es"
  "es:en"
  "en:fr"
  "fr:en"
)

# ── Behaviour ────────────────────────────────────────────────────────────────

MIRROR="https://download.kiwix.org/zim"
MIN_FREE_GB=50          # refuse to start if less free space than this
CURL_RETRIES=10
MAX_PARALLEL_STAGES=3   # independent fetch-* stages to run at the same time
MAX_PARALLEL_DOWNLOADS=3 # ZIM downloads to run at the same time
